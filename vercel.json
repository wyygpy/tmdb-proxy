{
    "version": 2,
    "redirects": [
        {
            "source": "/",
            "destination": "https://github.com/imaliang/tmdb-proxy",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/t/p/:path*",
            "destination": "https://images.tmdb.org/t/p/:path*"
        },
        // 新增匹配机制
        {
            "source": "/:size(w\\d+|h\\d+|original)/:path*",
            "destination": "https://images.tmdb.org/t/p/:size/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/api/tmdb.js"
        }
    ]
}
